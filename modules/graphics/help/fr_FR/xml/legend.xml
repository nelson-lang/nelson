  <language>fr_FR</language>
  <keyword>legend</keyword>
  <short_description>Ajoute une légende aux axes.</short_description>
  <syntax>
    <syntax_item>legend()</syntax_item>
    <syntax_item>legend(label1, ..., labelN)</syntax_item>
    <syntax_item>legend(labels)</syntax_item>
    <syntax_item>legend(&apos;off&apos;)</syntax_item>
    <syntax_item>legend(&apos;hide&apos;)</syntax_item>
    <syntax_item>legend(&apos;show&apos;)</syntax_item>
    <syntax_item>legend(&apos;toggle&apos;)</syntax_item>
    <syntax_item>legend(&apos;boxon&apos;)</syntax_item>
    <syntax_item>legend(&apos;boxoff&apos;)</syntax_item>
    <syntax_item>legend(ax, ...)</syntax_item>
    <syntax_item>legend(..., &apos;Location&apos;, lcn)</syntax_item>
    <syntax_item>legend(..., propertyName, propertyValue)</syntax_item>
    <syntax_item>L = legend(...)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>label1, ..., labelN</param_name>
      <param_description
      >Définit les étiquettes de la légende : vecteurs ligne de caractères.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>labels</param_name>
      <param_description
      >Cellule de vecteurs de caractères ou tableau de chaînes.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>
        &apos;off&apos;
      </param_name>
      <param_description>Supprime la légende.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>
        &apos;toggle&apos;
      </param_name>
      <param_description
      >Active/désactive la visibilité de la légende.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>
        &apos;hide&apos;
      </param_name>
      <param_description>Masque la légende.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>
        &apos;show&apos;
      </param_name>
      <param_description>Affiche la légende.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>
        &apos;boxon&apos;
      </param_name>
      <param_description
      >Affiche un encadré autour de la légende.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>
        &apos;boxoff&apos;
      </param_name>
      <param_description
      >Masque l&apos;encadré autour de la légende.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>ax</param_name>
      <param_description>Axes à rendre courant.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>lcn</param_name>
      <param_description
      > Emplacement de la légende : une chaîne (&apos;NE&apos; par défaut).</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>propertyName</param_name>
      <param_description
      >Une chaîne scalaire ou un vecteur ligne de caractères.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>propertyValue</param_name>
      <param_description>Une valeur.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>L</param_name>
      <param_description>Un objet graphique : type axes.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>legend</b> crée une légende dans la figure courante.          </p>
    <p>
      <b>Emplacement de la légende sur le graphique :</b>
    </p>
    <p />
    <p>
      &apos;northeast&apos; ou &apos;NE&apos; : En haut à droite (par défaut).</p>
    <p>
      &apos;north&apos; ou &apos;N&apos; : En haut au centre.</p>
    <p>
      &apos;south&apos; ou &apos;S&apos; : En bas au centre.</p>
    <p>
      &apos;east&apos; ou &apos;E&apos; : Au milieu à droite.</p>
    <p>
      &apos;west&apos; ou &apos;W&apos; : Au milieu à gauche.</p>
    <p>
      &apos;northwest&apos; ou &apos;NW&apos; : En haut à gauche.</p>
    <p>
      &apos;southeast&apos; ou &apos;SE&apos; : En bas à droite.</p>
    <p>
      &apos;southwest&apos; ou &apos;SW&apos; : En bas à gauche.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="adv-cli"
      ><![CDATA[f = figure();
x = linspace(0,10);
y1 = sin(x);
y2 = cos(x);
ax = gca();
plot(ax, x, y1);
plot(ax, x, y2);
legend('sin(x)', 'cos(x)', 'Location', 'N')]]></example_item_data>
      <example_item_img
        src="../../images/legend.svg"
        align="middle"
        generate="true"
      />
    </example_item>
  </examples>
