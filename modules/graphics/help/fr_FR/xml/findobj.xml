  <language>fr_FR</language>
  <keyword>findobj</keyword>
  <short_description>Trouve des objets graphiques avec des proprietes donnees.</short_description>
  <syntax>
    <syntax_item>h = findobj()</syntax_item>
    <syntax_item>h = findobj(prop, value)</syntax_item>
    <syntax_item>h = findobj(objhandles, prop, value)</syntax_item>
    <syntax_item>h = findobj(objhandles, &apos;flat&apos;, ...)</syntax_item>
    <syntax_item>h = findobj(objhandles, &apos;-depth&apos;, d, ...)</syntax_item>
    <syntax_item>h = findobj(..., &apos;-property&apos;, prop)</syntax_item>
    <syntax_item>h = findobj(..., &apos;-regexp&apos;, prop, expr)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>objhandles</param_name>
      <param_description>objet graphique ou tableau d&apos;objets graphiques depuis lesquels chercher.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>prop</param_name>
      <param_description>nom de propriete sous forme de vecteur de caracteres ou chaine scalaire.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>value</param_name>
      <param_description>valeur de propriete a rechercher.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>d</param_name>
      <param_description>profondeur de recherche, entiere positive ou nulle, ou Inf.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>expr</param_name>
      <param_description>expression reguliere appliquee a une propriete texte.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>h</param_name>
      <param_description>tableau colonne des objets graphiques trouves.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>findobj</b> parcourt la hierarchie graphique depuis l&apos;objet racine ou depuis les objets graphiques fournis. Les objets dont <b>HandleVisibility</b> vaut <b>
        &apos;off&apos;
      </b>, ainsi que leurs descendants, ne sont pas retournes.</p>
    <p>Les predicats de proprietes peuvent etre combines avec <b>
        &apos;-and&apos;
      </b>, <b>
        &apos;-or&apos;
      </b>, <b>
        &apos;-xor&apos;
      </b> et <b>
        &apos;-not&apos;
      </b>. Les tableaux de cellules permettent de grouper les expressions.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="adv-cli"><![CDATA[close all
plot(rand(5))
h = findobj('Type', 'line')]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="adv-cli"><![CDATA[close all
plot(1:10, 'Tag', 'linear')
h = findobj('-regexp', 'Tag', 'lin')]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="adv-cli"><![CDATA[close all
plot(1:10, 'Tag', 'linear')
hold on
plot((1:10).^2, 'Tag', 'quadratic')
h = findobj('Type', 'line', '-and', '-not', {'Tag', 'linear'})]]></example_item_data>
    </example_item>
  </examples>
