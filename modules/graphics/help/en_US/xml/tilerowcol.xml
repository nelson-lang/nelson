  <language>en_US</language>
  <keyword>tilerowcol</keyword>
  <short_description>Get row and column indices from tile number or graphics object.</short_description>
  <syntax>
    <syntax_item>[row, col] = tilerowcol(t, tilenum)</syntax_item>
    <syntax_item>[row, col] = tilerowcol(obj)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>t</param_name>
      <param_description>TiledChartLayout object.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>tilenum</param_name>
      <param_description>Tile number: positive integer or array.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>obj</param_name>
      <param_description>Graphics object (axes) created by nexttile.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>row</param_name>
      <param_description>Row index: positive integer, or NaN for invalid or edge tiles.</param_description>
    </param_output_item>
    <param_output_item>
      <param_name>col</param_name>
      <param_description>Column index: positive integer, or NaN for invalid or edge tiles.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>tilerowcol(t, tilenum)</b> returns the row and column indices for the given tile number in the TiledChartLayout t.</p>
    <p>
      <b>tilerowcol(obj)</b> returns the row and column of the tile occupied by the axes object obj.</p>
    <p>Returns NaN for out-of-range tile numbers or for edge tile axes.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Get row and column from tile number</example_item_description>
      <example_item_data><![CDATA[t = tiledlayout(2, 3);
[row, col] = tilerowcol(t, 4)
]]></example_item_data>
    </example_item>
  </examples>
