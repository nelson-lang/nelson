  <language>en_US</language>
  <keyword>addvars</keyword>
  <short_description>Add variables to a table.</short_description>
  <syntax>
    <syntax_item>TB = addvars(TA, X)</syntax_item>
    <syntax_item>TB = addvars(TA, X1, ... , XN, 'NewVariableNames', names)</syntax_item>
    <syntax_item>TB = addvars(TA, X, 'Before', varName)</syntax_item>
    <syntax_item>TB = addvars(TA, X, 'After', varName)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>TA</param_name>
      <param_description>Input table.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>X, X1, ... , XN</param_name>
      <param_description>Variable data to add. Each variable must have the same number of rows as <b>TA</b>.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>names</param_name>
      <param_description>Names for the new variables.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>varName</param_name>
      <param_description>Reference variable used with <b>Before</b> or <b>After</b>.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>TB</param_name>
      <param_description>Table with added variables.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p><b>addvars</b> adds one or more variables to a table and updates <b>T.Properties.VariableNames</b>.</p>
    <p>New variables are appended by default. Use <b>Before</b> or <b>After</b> to choose the insertion position.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Add a variable at the end of a table</example_item_description>
      <example_item_data
        runnable="cli"
      ><![CDATA[T = table([1; 2], 'VariableNames', {'A'});
T = addvars(T, [3; 4], 'NewVariableNames', {'B'})]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Add a variable before an existing variable</example_item_description>
      <example_item_data
        runnable="cli"
      ><![CDATA[T = table([1; 2], [5; 6], 'VariableNames', {'A', 'C'});
T = addvars(T, [3; 4], 'NewVariableNames', {'B'}, 'Before', 'C')]]></example_item_data>
    </example_item>
  </examples>
