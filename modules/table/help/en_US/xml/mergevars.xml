  <language>en_US</language>
  <keyword>mergevars</keyword>
  <short_description>Merge table variables.</short_description>
  <syntax>
    <syntax_item>T2 = mergevars(T, vars)</syntax_item>
    <syntax_item>T2 = mergevars(T, vars, 'NewVariableName', name)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>T</param_name>
      <param_description>Input table.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>vars</param_name>
      <param_description>Variables to merge.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>T2</param_name>
      <param_description>Table with merged variables.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>mergevars</b> combines selected variables into one table variable.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[T = table([1; 2], [3; 4], 'VariableNames', {'A', 'B'});
R = mergevars(T, {'A', 'B'}, 'NewVariableName', 'AB')]]></example_item_data>
    </example_item>
  </examples>
