  <language>en_US</language>
  <keyword>splitvars</keyword>
  <short_description>Split multicolumn table variables.</short_description>
  <syntax>
    <syntax_item>T2 = splitvars(T, vars)</syntax_item>
    <syntax_item>T2 = splitvars(T, vars, 'NewVariableNames', names)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>T</param_name>
      <param_description>Input table.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>vars</param_name>
      <param_description>Variables to split.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>T2</param_name>
      <param_description>Table with split variables.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>splitvars</b> replaces a multicolumn variable with separate table variables.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[T = table([1 3; 2 4], 'VariableNames', {'AB'});
R = splitvars(T, 'AB', 'NewVariableNames', {'A', 'B'})]]></example_item_data>
    </example_item>
  </examples>
  <see_also>
    <see_also_item>
      <link linkend="${table}mergevars">mergevars</link>
    </see_also_item>
  </see_also>
