  <language>en_US</language>
  <keyword>stack</keyword>
  <short_description>Stack table variables into rows.</short_description>
  <syntax>
    <syntax_item>S = stack(T, vars)</syntax_item>
    <syntax_item>S = stack(T, vars, 'NewDataVariableName', name)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>T</param_name>
      <param_description>Input table.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>vars</param_name>
      <param_description>Variables to stack.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>S</param_name>
      <param_description>Stacked table.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>stack</b> converts selected variables into a single data variable and an indicator variable.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[T = table({'a'; 'b'}, [1; 2], [3; 4], 'VariableNames', {'ID', 'X', 'Y'});
S = stack(T, {'X', 'Y'}, 'NewDataVariableName', 'Value')]]></example_item_data>
    </example_item>
  </examples>
  <see_also>
    <see_also_item>
      <link linkend="${table}unstack">unstack</link>
    </see_also_item>
  </see_also>
