  <language>fr_FR</language>
  <keyword>convertvars</keyword>
  <short_description>Convertit des variables de table.</short_description>
  <syntax>
    <syntax_item>T2 = convertvars(T, vars, fun)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>T</param_name>
      <param_description>Table d'entree.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>vars</param_name>
      <param_description>Variables a convertir.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>fun</param_name>
      <param_description>Fonction appliquee aux variables selectionnees.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>T2</param_name>
      <param_description>Table avec variables converties.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>convertvars</b> applique une fonction de conversion aux variables selectionnees.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[T = table([1; 2], 'VariableNames', {'A'});
R = convertvars(T, 'A', @(x) single(x))]]></example_item_data>
    </example_item>
  </examples>
