  <language>fr_FR</language>
  <keyword>summary</keyword>
  <short_description>Resume des variables d'une table.</short_description>
  <syntax>
    <syntax_item>S = summary(T)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>T</param_name>
      <param_description>Table d'entree.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>S</param_name>
      <param_description>Structure contenant les informations de resume.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p><b>summary</b> retourne la taille et le type de chaque variable de table.</p>
    <p>Les variables numeriques incluent aussi les valeurs minimum, maximum et moyenne.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Resumer une table</example_item_description>
      <example_item_data
        runnable="cli"
      ><![CDATA[T = table([1; 2; 3], ["a"; "b"; "c"], 'VariableNames', {'A', 'Label'});
S = summary(T)]]></example_item_data>
    </example_item>
  </examples>
