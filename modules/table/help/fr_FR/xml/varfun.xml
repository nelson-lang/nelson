  <language>fr_FR</language>
  <keyword>varfun</keyword>
  <short_description>Applique une fonction aux variables d'une table.</short_description>
  <syntax>
    <syntax_item>R = varfun(fun, T)</syntax_item>
    <syntax_item>R = varfun(fun, T, 'InputVariables', vars)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>fun</param_name>
      <param_description>Fonction.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>T</param_name>
      <param_description>Table d'entree.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>R</param_name>
      <param_description>Resultat sous forme de table, tableau ou cellule selon OutputFormat.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>varfun</b> applique une fonction independamment aux variables selectionnees.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[T = table([1; 2; 4], [10; 20; 30], 'VariableNames', {'X', 'Y'});
R = varfun(@mean, T)]]></example_item_data>
    </example_item>
  </examples>
