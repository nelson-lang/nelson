  <language>fr_FR</language>
  <keyword>outerjoin</keyword>
  <short_description>Jointure externe de deux tables.</short_description>
  <syntax>
    <syntax_item>T = outerjoin(left, right)</syntax_item>
    <syntax_item>T = outerjoin(left, right, 'Keys', keys)</syntax_item>
    <syntax_item>T = outerjoin(left, right, 'MergeKeys', true)</syntax_item>
    <syntax_item>T = outerjoin(left, right, 'LeftVariables', leftVars, 'RightVariables', rightVars)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>left, right</param_name>
      <param_description>Tables d'entree.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>keys</param_name>
      <param_description>Noms des variables cles.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>leftVars, rightVars</param_name>
      <param_description>Variables a conserver depuis les tables gauche et droite.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>T</param_name>
      <param_description>Table jointe.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>outerjoin</b> combine les lignes des deux tables et conserve les lignes non appariees selon le type de jointure.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[L = table([1; 2], [10; 20], 'VariableNames', {'Key', 'LeftValue'});
R = table([2; 3], [200; 300], 'VariableNames', {'Key', 'RightValue'});
J = outerjoin(L, R, 'Keys', 'Key')]]></example_item_data>
    </example_item>
  </examples>
