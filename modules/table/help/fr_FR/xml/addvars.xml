  <language>fr_FR</language>
  <keyword>addvars</keyword>
  <short_description>Ajoute des variables a une table.</short_description>
  <syntax>
    <syntax_item>TB = addvars(TA, X)</syntax_item>
    <syntax_item>TB = addvars(TA, X1, ... , XN, 'NewVariableNames', names)</syntax_item>
    <syntax_item>TB = addvars(TA, X, 'Before', varName)</syntax_item>
    <syntax_item>TB = addvars(TA, X, 'After', varName)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>TA</param_name>
      <param_description>Table d'entree.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>X, X1, ... , XN</param_name>
      <param_description>Donnees de variables a ajouter. Chaque variable doit avoir le meme nombre de lignes que <b>TA</b>.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>names</param_name>
      <param_description>Noms des nouvelles variables.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>varName</param_name>
      <param_description>Variable de reference utilisee avec <b>Before</b> ou <b>After</b>.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>TB</param_name>
      <param_description>Table avec variables ajoutees.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p><b>addvars</b> ajoute une ou plusieurs variables et met a jour <b>T.Properties.VariableNames</b>.</p>
    <p>Les nouvelles variables sont ajoutees a la fin par defaut. Utilisez <b>Before</b> ou <b>After</b> pour choisir la position.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Ajouter une variable a la fin d'une table</example_item_description>
      <example_item_data
        runnable="cli"
      ><![CDATA[T = table([1; 2], 'VariableNames', {'A'});
T = addvars(T, [3; 4], 'NewVariableNames', {'B'})]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Ajouter une variable avant une variable existante</example_item_description>
      <example_item_data
        runnable="cli"
      ><![CDATA[T = table([1; 2], [5; 6], 'VariableNames', {'A', 'C'});
T = addvars(T, [3; 4], 'NewVariableNames', {'B'}, 'Before', 'C')]]></example_item_data>
    </example_item>
  </examples>
