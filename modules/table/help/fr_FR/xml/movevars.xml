  <language>fr_FR</language>
  <keyword>movevars</keyword>
  <short_description>Deplace des variables dans une table.</short_description>
  <syntax>
    <syntax_item>TB = movevars(TA, vars, 'Before', location)</syntax_item>
    <syntax_item>TB = movevars(TA, vars, 'After', location)</syntax_item>
    <syntax_item>TB = movevars(TA, vars, 'Before', ref)</syntax_item>
    <syntax_item>TB = movevars(TA, vars, 'After', ref)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>TA</param_name>
      <param_description>Table d'entree.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>vars</param_name>
      <param_description>Variables a deplacer, specifiees par noms, indices ou selecteurs logiques.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>ref</param_name>
      <param_description>Variable de reference utilisee avec <b>Before</b> ou <b>After</b>.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>TB</param_name>
      <param_description>Table avec variables reordonnees.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p><b>movevars</b> reordonne les variables d'une table sans changer leurs donnees. L'emplacement peut etre un nom de variable ou un indice de variable.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Deplacer une variable en premiere position</example_item_description>
      <example_item_data
        runnable="cli"
      ><![CDATA[T = table([1; 2], [3; 4], 'VariableNames', {'A', 'B'});
T = movevars(T, 'B', 'Before', 1)]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Deplacer une variable apres une autre variable</example_item_description>
      <example_item_data
        runnable="cli"
      ><![CDATA[T = table([1; 2], [3; 4], [5; 6], 'VariableNames', {'A', 'B', 'C'});
T = movevars(T, 'A', 'After', 'C')]]></example_item_data>
    </example_item>
  </examples>
