  <language>fr_FR</language>
  <keyword>rows2vars</keyword>
  <short_description>Reoriente les lignes en variables.</short_description>
  <syntax>
    <syntax_item>T2 = rows2vars(T)</syntax_item>
    <syntax_item>T2 = rows2vars(T, 'VariableNamesSource', var)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>T</param_name>
      <param_description>Table d'entree.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>T2</param_name>
      <param_description>Table reorientee.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>rows2vars</b> cree des variables de table a partir des lignes de la table d'entree.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[T = table({'r1'; 'r2'}, [10; 20], 'VariableNames', {'Name', 'Value'});
R = rows2vars(T, 'VariableNamesSource', 'Name')]]></example_item_data>
    </example_item>
  </examples>
