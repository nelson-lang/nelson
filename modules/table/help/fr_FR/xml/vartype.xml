  <language>fr_FR</language>
  <keyword>vartype</keyword>
  <short_description>Selectionne des variables de table par type.</short_description>
  <syntax>
    <syntax_item>S = vartype(typeName)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>typeName</param_name>
      <param_description>Nom de classe utilise pour selectionner les variables.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>S</param_name>
      <param_description>Selecteur de type de variable.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>vartype</b> cree un selecteur utilisable par des fonctions de table comme <b>varfun</b> et <b>convertvars</b>.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[T = table([1; 2], {'a'; 'b'}, 'VariableNames', {'A', 'B'});
R = varfun(@mean, T, 'InputVariables', vartype('double'))]]></example_item_data>
    </example_item>
  </examples>
