  <language>fr_FR</language>
  <keyword>rmprop</keyword>
  <short_description>Supprime une propriete personnalisee d'une table.</short_description>
  <syntax>
    <syntax_item>TB = rmprop(TA, name)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>TA</param_name>
      <param_description>Table d'entree.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>name</param_name>
      <param_description>Nom de la propriete personnalisee.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>TB</param_name>
      <param_description>Table avec propriete personnalisee supprimee.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p><b>rmprop</b> supprime une propriete personnalisee de <b>T.Properties.CustomProperties</b>.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Supprimer une propriete personnalisee</example_item_description>
      <example_item_data
        runnable="cli"
      ><![CDATA[T = table([1; 2], 'VariableNames', {'A'});
T = addprop(T, 'Source', 'table');
T.Properties.CustomProperties.Source = 'demo';
T = rmprop(T, 'Source')]]></example_item_data>
    </example_item>
  </examples>
