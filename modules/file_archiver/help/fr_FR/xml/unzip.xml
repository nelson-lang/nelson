  <language>fr_FR</language>
  <keyword>unzip</keyword>
  <short_description>Décompresser une archive zip.</short_description>
  <syntax>
    <syntax_item>res = unzip(zipname)</syntax_item>
    <syntax_item>res = unzip(zipname, rootdir)</syntax_item>
    <syntax_item>res = unzip(___, 'Password', password)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>zipname</param_name>
      <param_description
      >une chaîne : nom du fichier d&apos;archive zip. Si zipname n&apos;a pas d&apos;extension, Nelson essaie zipname avec .zip ajouté.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>rootdir</param_name>
      <param_description
      >un vecteur de caractères ou une chaîne : chemin racine pour les fichiers à décompresser. Les dossiers manquants sont créés.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>password</param_name>
      <param_description
      >un vecteur de caractères ou une chaîne : mot de passe utilisé pour extraire les entrées chiffrées de l&apos;archive.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>res</param_name>
      <param_description
      >un tableau de cellules de vecteurs de caractères contenant les noms des fichiers décompressés. Les noms sont relatifs lorsque rootdir est relatif et absolus lorsque rootdir est absolu.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>unzip</b> extrait le contenu archivé. Les horodatages et attributs sont préservés pour chaque fichier.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[zip([tempdir(), 'test'], [nelsonroot(), '/module_skeleton']);
r = unzip([tempdir(), 'test.zip'], [tempdir(), createGUID()])]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[zip([tempdir(), 'protected'], [nelsonroot(), '/module_skeleton/builder.m'], 'Password', 'secret', 'EncryptionMethod', 'zipcrypto');
r = unzip([tempdir(), 'protected'], [tempdir(), createGUID()], 'Password', 'secret')]]></example_item_data>
    </example_item>
  </examples>
