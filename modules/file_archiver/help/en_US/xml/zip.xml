  <language>en_US</language>
  <keyword>zip</keyword>
  <short_description>Compress files into zip file.</short_description>
  <syntax>
    <syntax_item>res = zip(zipname, files)</syntax_item>
    <syntax_item>res = zip(zipname, files, rootdir)</syntax_item>
    <syntax_item>res = zip(..., 'Password', password, 'EncryptionMethod', method)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>zipname</param_name>
      <param_description
      >a string: zip archive destination file. If zipname does not end with .zip, Nelson appends .zip.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>files</param_name>
      <param_description
      >a character vector, a cell array of character vectors, or a string array: names of files or folders to compress.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>rootdir</param_name>
      <param_description
      >a character vector or string scalar: root path for the files to compress.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>password</param_name>
      <param_description
      >a character vector or string scalar: password used to encrypt archive entries.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>method</param_name>
      <param_description
      >encryption method: 'zipcrypto', or, when AES is supported by the build, 'aes-128', 'aes128', 'aes-256', or 'aes256'. Password and EncryptionMethod must be specified together.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>res</param_name>
      <param_description
      >a cell array of character vectors containing the archive-relative names of the files included in the zip archive.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>zip</b> compresses files and directories into a zip archive.</p>
    <p>Encrypted archives can be created by specifying both <b>Password</b> and <b>EncryptionMethod</b>.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[zip([tempdir(), 'test'], [nelsonroot(), '/module_skeleton'])
]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[zip([tempdir(), 'protected'], [nelsonroot(), '/module_skeleton/builder.m'], 'Password', 'secret', 'EncryptionMethod', 'aes-256')
]]></example_item_data>
    </example_item>
  </examples>
