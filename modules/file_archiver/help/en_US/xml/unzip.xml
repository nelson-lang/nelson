  <language>en_US</language>
  <keyword>unzip</keyword>
  <short_description>Decompress zip file.</short_description>
  <syntax>
    <syntax_item>res = unzip(zipname)</syntax_item>
    <syntax_item>res = unzip(zipname, rootdir)</syntax_item>
    <syntax_item>res = unzip(___, 'Password', password)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>zipname</param_name>
      <param_description
      >a string: zip archive filename. If zipname has no extension, Nelson tries zipname with .zip appended.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>rootdir</param_name>
      <param_description
      >a character vector or string scalar: root path for the files to decompress. Missing folders are created.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>password</param_name>
      <param_description
      >a character vector or string scalar: password used to extract encrypted archive entries.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>res</param_name>
      <param_description
      >a cell array of character vectors containing the names of the files decompressed. Names are relative when rootdir is relative and absolute when rootdir is absolute.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>unzip</b> extracts archived contents. Timestamps and attributes are preserved for each file.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[zip([tempdir(), 'test'], [nelsonroot(), '/module_skeleton']);
r = unzip([tempdir(), 'test.zip'], [tempdir(), createGUID()])]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[zip([tempdir(), 'protected'], [nelsonroot(), '/module_skeleton/builder.m'], 'Password', 'secret', 'EncryptionMethod', 'zipcrypto');
r = unzip([tempdir(), 'protected'], [tempdir(), createGUID()], 'Password', 'secret')]]></example_item_data>
    </example_item>
  </examples>
