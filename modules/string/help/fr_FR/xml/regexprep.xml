  <language>fr_FR</language>
  <keyword>regexprep</keyword>
  <short_description>Remplace du texte avec une expression reguliere.</short_description>
  <syntax>
    <syntax_item>newStr = regexprep(str, expression, replace)</syntax_item>
    <syntax_item>newStr = regexprep(..., option)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>str</param_name>
      <param_description>texte d&apos;entree.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>expression</param_name>
      <param_description>expression reguliere.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>replace</param_name>
      <param_description>texte de remplacement. Les jetons $1 et $&amp; sont acceptes.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>newStr</param_name>
      <param_description>texte apres remplacement.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>regexprep</b> remplace les occurrences trouvees par une expression reguliere.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[
regexprep('a1 b2', '(\w)(\d)', '$2-$1')
]]></example_item_data>
    </example_item>
  </examples>
  <see_also>
