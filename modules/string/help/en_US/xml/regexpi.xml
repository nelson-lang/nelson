  <language>en_US</language>
  <keyword>regexpi</keyword>
  <short_description>Match regular expression, ignoring case.</short_description>
  <syntax>
    <syntax_item>startIndex = regexpi(str, expression)</syntax_item>
    <syntax_item>out = regexpi(str, expression, outkey)</syntax_item>
    <syntax_item>out = regexpi(..., option)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>str</param_name>
      <param_description>a character vector, string array, or cell array of character vectors.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>expression</param_name>
      <param_description>a regular expression.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>outkey</param_name>
      <param_description>same output keys as <b>regexp</b>.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>out</param_name>
      <param_description>match indices, matches, tokens, named token structures, or split text.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>regexpi</b> is equivalent to <b>regexp</b> with case-insensitive matching enabled by default.</p>
  </description>
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[
regexpi('ABC abc', 'abc', 'match')
]]></example_item_data>
    </example_item>
  </examples>
  <see_also>
    <see_also_item>
      <link linkend="${string}regexp">regexp</link>
    </see_also_item>
  </see_also>
