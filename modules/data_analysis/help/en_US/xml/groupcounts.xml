  <language>en_US</language>
  <keyword>groupcounts</keyword>
  <short_description>Count groups.</short_description>
  <syntax>
    <syntax_item>counts = groupcounts(A)</syntax_item>
    <syntax_item>[counts, groups] = groupcounts(A)</syntax_item>
    <syntax_item>G = groupcounts(T, groupVars)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>A</param_name>
      <param_description>Input array.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>T</param_name>
      <param_description>Input table.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>groupVars</param_name>
      <param_description>Grouping variables.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>counts</param_name>
      <param_description>Number of elements in each group.</param_description>
    </param_output_item>
    <param_output_item>
      <param_name>groups</param_name>
      <param_description>Unique group values.</param_description>
    </param_output_item>
    <param_output_item>
      <param_name>G</param_name>
      <param_description>Table containing groups, counts, and percentages.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p><b>groupcounts</b> counts the number of elements or table rows in each group.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[[counts, groups] = groupcounts([1; 1; 2; 3; 3; 3])
T = table({'a'; 'a'; 'b'}, [1; 2; 4], 'VariableNames', {'G', 'X'});
C = groupcounts(T, 'G')]]></example_item_data>
    </example_item>
  </examples>
