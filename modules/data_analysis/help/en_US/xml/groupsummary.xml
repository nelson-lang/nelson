  <language>en_US</language>
  <keyword>groupsummary</keyword>
  <short_description>Compute grouped table summaries.</short_description>
  <syntax>
    <syntax_item>G = groupsummary(T, groupVars)</syntax_item>
    <syntax_item>G = groupsummary(T, groupVars, method, dataVars)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>T</param_name>
      <param_description>Input table.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>groupVars</param_name>
      <param_description>Grouping variables.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>method</param_name>
      <param_description>Summary method such as sum, mean, min, max, or count.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>dataVars</param_name>
      <param_description>Variables to summarize.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>G</param_name>
      <param_description>Grouped summary table.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p><b>groupsummary</b> groups table rows and computes summary values for selected variables.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[T = table({'a'; 'a'; 'b'}, [1; 2; 4], 'VariableNames', {'G', 'X'});
G = groupsummary(T, 'G', 'sum', 'X')]]></example_item_data>
    </example_item>
  </examples>
