  <language>en_US</language>
  <keyword>fillmissing</keyword>
  <short_description>Fill missing values.</short_description>
  <syntax>
    <syntax_item>B = fillmissing(A, method)</syntax_item>
    <syntax_item>B = fillmissing(A, 'constant', value)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>A</param_name>
      <param_description>Input array or table.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>method</param_name>
      <param_description>Fill method.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>B</param_name>
      <param_description>Data with missing values filled.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>fillmissing</b> replaces missing values using the specified method.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[T = table([1; NaN; 3], 'VariableNames', {'A'});
R = fillmissing(T, 'constant', 0)]]></example_item_data>
    </example_item>
  </examples>
