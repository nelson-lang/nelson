  <language>fr_FR</language>
  <keyword>intersect</keyword>
  <short_description>Intersection ensembliste de deux tableaux.</short_description>
  <syntax>
    <syntax_item>C = intersect(A, B)</syntax_item>
    <syntax_item>[C, ia, ib] = intersect(A, B)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item><param_name>A, B</param_name><param_description>Tableaux d'entree.</param_description></param_input_item>
  </param_input>
  <param_output>
    <param_output_item><param_name>C</param_name><param_description>Valeurs triees communes a <b>A</b> et <b>B</b>.</param_description></param_output_item>
    <param_output_item><param_name>ia, ib</param_name><param_description>Indices dans <b>A</b> et <b>B</b>.</param_description></param_output_item>
  </param_output>
  <description>
    <p><b>intersect(A, B)</b> retourne les valeurs triees presentes dans les deux tableaux.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item><example_item_type>nelson</example_item_type><example_item_description /><example_item_data runnable="cli"><![CDATA[A = [5 7 1];
B = [3 1 1];
C = intersect(A, B)]]></example_item_data></example_item>
  </examples>
