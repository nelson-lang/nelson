  <language>fr_FR</language>
  <keyword>isbetween</keyword>
  <short_description>Determine les elements compris entre des bornes inferieure et superieure.</short_description>
  <syntax>
    <syntax_item>TF = isbetween(A, lower, upper)</syntax_item>
    <syntax_item>TF = isbetween(A, lower, upper, intervalType)</syntax_item>
    <syntax_item>TF = isbetween(..., name, value)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>A</param_name>
      <param_description>tableau ou table.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>lower, upper</param_name>
      <param_description>bornes inferieure et superieure.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>intervalType</param_name>
      <param_description>
        &apos;closed&apos;, &apos;open&apos;, &apos;openleft&apos;, &apos;openright&apos;, &apos;closedleft&apos; ou &apos;closedright&apos;.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>name, value</param_name>
      <param_description>Pour les tables, prend en charge &apos;DataVariables&apos; et &apos;OutputFormat&apos;.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>TF</param_name>
      <param_description>tableau logique ou table logique.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>isbetween</b> renvoie true lorsque <b>A</b> est dans l&apos;intervalle defini par <b>lower</b> et <b>upper</b>. L&apos;intervalle par defaut est ferme.</p>
  </description>
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[A = [1 2 3 4 5];
isbetween(A, 2, 4)
isbetween(A, 2, 4, 'open')]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[T = table([1; 2; 3], [4; 5; 6], 'VariableNames', {'A', 'B'});
isbetween(T, 2, 5)
isbetween(T, 2, 5, 'DataVariables', 'B', 'OutputFormat', 'tabular')]]></example_item_data>
    </example_item>
  </examples>
