  <language>fr_FR</language>
  <keyword>rmmissing</keyword>
  <short_description>Supprime les donnees manquantes.</short_description>
  <syntax>
    <syntax_item>B = rmmissing(A)</syntax_item>
    <syntax_item>B = rmmissing(A, dim)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>A</param_name>
      <param_description>Tableau ou table d'entree.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>dim</param_name>
      <param_description>Dimension de traitement.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>B</param_name>
      <param_description>Donnees sans lignes, colonnes ou elements manquants.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>rmmissing</b> supprime les donnees manquantes des tableaux et supprime les lignes ou variables contenant des valeurs manquantes dans les tables.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[A = [1 NaN; 2 3; NaN 4];
B = rmmissing(A)]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data runnable="cli"><![CDATA[T = table([1; NaN; 3], {'a'; ''; 'c'}, 'VariableNames', {'A', 'B'});
R = rmmissing(T)]]></example_item_data>
    </example_item>
  </examples>
