  <language>en_US</language>
  <keyword>erfinv</keyword>
  <short_description>Inverse error function</short_description>
  <syntax>
    <syntax_item>R = erfinv(X)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>X</param_name>
      <param_description
      >a real single or real double scalar, vector, matrix, or multidimensional array. Sparse and complex inputs are not supported.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>R</param_name>
      <param_description
      >inverse error function values, returned with the same size and floating-point class as X.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>erfinv</b> computes the inverse error function element by element.</p>
    <p>The inverse error function is defined by:</p>
    <latex>erfinv(erf(x)) = x</latex>
    <p>      Values outside the interval [-1, 1] return NaN. The values -1 and 1 return -Inf and Inf, respectively.</p>
    <p>      For expressions of the form <b>erfinv(1 - x)</b>, use <b>erfcinv(x)</b> for better accuracy when x is small.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Find the inverse error function of a scalar.</example_item_description>
      <example_item_data runnable="cli"><![CDATA[R = erfinv(0.25)]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Evaluate boundary and out-of-domain values.</example_item_description>
      <example_item_data runnable="cli"><![CDATA[R = erfinv([-2 -1 1 2])]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Find the inverse error function of the elements of a matrix.</example_item_description>
      <example_item_data runnable="cli"><![CDATA[M = [0 -0.5; 0.9 -0.2];
R = erfinv(M)]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description>Generate normally distributed values from uniform values in [-1, 1].</example_item_description>
      <example_item_data runnable="cli"><![CDATA[x = -1 + 2 * rand(1, 10000);
y = sqrt(2) * erfinv(x);]]></example_item_data>
    </example_item>
  </examples>
