  <language>en_US</language>
  <keyword>interp1</keyword>
  <short_description>1-D data interpolation</short_description>
  <syntax>
    <syntax_item>vq = interp1(x, v, xq)</syntax_item>
    <syntax_item>vq = interp1(x, v, xq, method)</syntax_item>
    <syntax_item>vq = interp1(x, v, xq, method, extrapolation)</syntax_item>
    <syntax_item>vq = interp1(v, xq)</syntax_item>
    <syntax_item>vq = interp1(v, xq, method)</syntax_item>
    <syntax_item>vq = interp1(v, xq, method, extrapolation)</syntax_item>
    <syntax_item>pp = interp1(x, v, method, &apos;pp&apos;)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>x</param_name>
      <param_description>Sample points: vector.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>v</param_name>
      <param_description>Sample values: vector, matrix.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>xq</param_name>
      <param_description
      >Query points: scalar, vector, matrix.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>method</param_name>
      <param_description>Interpolation method: &apos;linear&apos;, &apos;nearest&apos;, &apos;next&apos;, &apos;previous&apos;, &apos;pchip&apos;, &apos;cubic&apos;, &apos;makima&apos;, or &apos;spline&apos;.</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>extrapolation</param_name>
      <param_description>
        &apos;extrap&apos; or a scalar value.</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>vq</param_name>
      <param_description
      >Interpolated values: scalar, vector, matrix.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>vq = interp1(x, v, xq)</b> returns interpolated values of a 1-D function at specific query points. The default method is linear interpolation.
    </p>
    <p>
      <b>pp = interp1(x, v, method, &apos;pp&apos;)</b> returns a piecewise polynomial structure that can be evaluated with <b>ppval</b>.
    </p>
  </description>
  <used_function />
  <bibliography
  >de Boor, C., A Practical Guide to Splines, Springer-Verlag, 1978.</bibliography>
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="adv-cli"
      ><![CDATA[f = figure();
v = [0  1.41  2  1.41  0  -1.41  -2  -1.41 0];
xq = 1.5:8.5;
vq = interp1(v,xq);
plot(1:9, v, 'o', xq, vq, '*');
legend('v','vq');]]></example_item_data>
      <example_item_img
        src="../../images/interp1.svg"
        align="middle"
        generate="true"
      />
    </example_item>
  </examples>
