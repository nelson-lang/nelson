  <language>fr_FR</language>
  <keyword>ferror</keyword>
  <short_description
  >Test des erreurs d&apos;E/S lecture/écriture.</short_description>
  <syntax>
    <syntax_item>msg = ferror(fid)</syntax_item>
    <syntax_item>[msg, code] = ferror(fid)</syntax_item>
    <syntax_item>ferror(fid, &apos;clear&apos;)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>fid</param_name>
      <param_description>un descripteur de fichier</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>code</param_name>
      <param_description
      >une valeur entière : 0 s&apos;il n&apos;y a pas d&apos;erreur. valeur négative si une erreur est détectée.</param_description>
    </param_output_item>
    <param_output_item>
      <param_name>msg</param_name>
      <param_description
      >un vecteur de caractères : message d&apos;erreur correspondant au code.</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>ferror</b> interroge le statut d&apos;erreur d&apos;un fichier.</p>
    <p>
      <b
      >ferror(fid, &apos;clear&apos;)</b> efface l&apos;indicateur d&apos;erreur pour le fichier spécifié.</p>
    <p
    >Pour plus d&apos;informations sur le message retourné, consultez le manuel de la bibliothèque d&apos;exécution C.</p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[filename = [tempdir(), 'test_ferror.csv'];
fid = fopen(filename, 'w');
res = fgets(fid);
[msg, code] = ferror(fid)
]]></example_item_data>
    </example_item>
  </examples>
