  <language>en_US</language>
  <keyword>intmax</keyword>
  <short_description
  >Return the largest integer that can be represented in an integer type.</short_description>
  <syntax>
    <syntax_item>imax = intmax()</syntax_item>
    <syntax_item>imax = intmax(classname)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>classname</param_name>
      <param_description>a string: by default: int32</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>imax</param_name>
      <param_description>largest integer</param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b
      >imax = intmax(classname)</b> the largest integer that can be represented in an integer type.</p>
    <p>Supported values for the string <b>classname</b> are:</p>
    <p>
      &apos;int8&apos;
    </p>
    <p>
      &apos;uint8&apos;
    </p>
    <p>
      &apos;int16&apos;
    </p>
    <p>
      &apos;uint16&apos;
    </p>
    <p>
      &apos;int32&apos;
    </p>
    <p>
      &apos;uint32&apos;
    </p>
    <p>
      &apos;int64&apos;
    </p>
    <p>
      &apos;uint64&apos;
    </p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[A = intmax('int64')
res = class(A)]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[A = intmax('uint32')
res = class(C)]]></example_item_data>
    </example_item>
  </examples>
