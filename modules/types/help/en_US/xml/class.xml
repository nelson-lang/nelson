  <language>en_US</language>
  <keyword>class</keyword>
  <short_description
  >Return classname of object or creates a named object.</short_description>
  <syntax>
    <syntax_item>name = class(var)</syntax_item>
    <syntax_item>obj = class(st, strname)</syntax_item>
  </syntax>
  <param_input>
    <param_input_item>
      <param_name>var</param_name>
      <param_description>a variable</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>st</param_name>
      <param_description>a struct</param_description>
    </param_input_item>
    <param_input_item>
      <param_name>strname</param_name>
      <param_description>a string: classname desired</param_description>
    </param_input_item>
  </param_input>
  <param_output>
    <param_output_item>
      <param_name>name</param_name>
      <param_description>a string</param_description>
    </param_output_item>
    <param_output_item>
      <param_name>obj</param_name>
      <param_description
      >an object of type &apos;strname&apos; based on struct &apos;st&apos;
      </param_description>
    </param_output_item>
  </param_output>
  <description>
    <p>
      <b>name = class(var)</b> returns the class of var variable.</p>
    <p>Standard classes are:</p>
    <p>
      &apos;cell&apos;
    </p>
    <p>
      &apos;struct&apos;
    </p>
    <p>
      &apos;single&apos;
    </p>
    <p>
      &apos;double&apos;
    </p>
    <p>
      &apos;logical&apos;
    </p>
    <p>
      &apos;char&apos;
    </p>
    <p>
      &apos;int8&apos;
    </p>
    <p>
      &apos;int16&apos;
    </p>
    <p>
      &apos;int32&apos;
    </p>
    <p>
      &apos;int64&apos;
    </p>
    <p>
      &apos;uint8&apos;
    </p>
    <p>
      &apos;uint16&apos;
    </p>
    <p>
      &apos;uint32&apos;
    </p>
    <p>
      &apos;uint64&apos;
    </p>
    <p>
      &apos;function_handle&apos;
    </p>
  </description>
  <used_function />
  <bibliography />
  <examples>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[A = 3;
res = class(A)]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[C = [1 ; 3];
res = class(C)]]></example_item_data>
    </example_item>
    <example_item>
      <example_item_type>nelson</example_item_type>
      <example_item_description />
      <example_item_data
        runnable="cli"
      ><![CDATA[addpath([nelsonroot(), '/modules/overload/examples/complex']);
c = complexObj(3,4);
class(c)]]></example_item_data>
    </example_item>
  </examples>
